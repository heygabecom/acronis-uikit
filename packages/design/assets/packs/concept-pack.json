{
  "$schema": "../schemas/pack.schema.json",
  "name": "concept-pack",
  "version": "1.0.0",
  "$type": "vector",

  "values": {
    "24": { "default": true },
    "16": { "$rules": ["scale-16"] },
    "32": { "$rules": ["scale-32"] }
  },

  "assets": {
    "icon-basic": {
      "$description": "R1 + R2: inherits pack values; ships only the canonical.",
      "values": {
        "24": { "$file": "./packs/concept-pack/icon-24.svg" }
      },
      "platforms": ["PD"],
      "metadata": { "category": [], "tags": [], "legacyNames": [] }
    },

    "icon-extended": {
      "$description": "R3: extends with a new 96 variant beyond pack values; 96 computes from the canonical (no $from).",
      "values": {
        "24": { "$file": "./packs/concept-pack/icon-24.svg" },
        "96": { "$rules": ["scale-96"] }
      },
      "platforms": ["PD"],
      "metadata": { "category": [], "tags": [], "legacyNames": [] }
    },

    "icon-rule-override": {
      "$description": "R4: overrides the pack-computed 16 with different rules (still from the canonical).",
      "values": {
        "24": { "$file": "./packs/concept-pack/icon-24.svg" },
        "16": { "$rules": ["stroke-2-5", "scale-16"] }
      },
      "platforms": ["PD"],
      "metadata": { "category": [], "tags": [], "legacyNames": [] }
    },

    "icon-opted-out": {
      "$description": "R5: opts out of the pack 32 via null.",
      "values": {
        "24": { "$file": "./packs/concept-pack/icon-24.svg" },
        "32": null
      },
      "platforms": ["PD"],
      "metadata": { "category": [], "tags": [], "legacyNames": [] }
    },

    "icon-file-override": {
      "$description": "R6: replaces the pack-computed 16 with its own binary.",
      "values": {
        "24": { "$file": "./packs/concept-pack/icon-alt-24.svg" },
        "16": { "$file": "./packs/concept-pack/icon-alt-16.svg" }
      },
      "platforms": ["PD"],
      "metadata": { "category": [], "tags": [], "legacyNames": [] }
    },

    "icon-multi-source": {
      "$description": "R7: ships an independent binary at every variant; asset values win over pack values.",
      "values": {
        "24": { "$file": "./packs/concept-pack/icon-alt-24.svg" },
        "16": { "$file": "./packs/concept-pack/icon-alt-16.svg" },
        "32": { "$file": "./packs/concept-pack/icon-alt-32.svg" }
      },
      "platforms": ["PD"],
      "metadata": { "category": [], "tags": [], "legacyNames": [] }
    },

    "image-raster": {
      "$description": "R8: asset-level $type override to raster; opts out of vector pack values.",
      "$type": "raster",
      "values": {
        "24": { "$file": "./packs/concept-pack/image-raster-24.png" },
        "16": null,
        "32": null
      },
      "platforms": ["PD"],
      "metadata": { "category": [], "tags": [], "legacyNames": [] }
    },

    "icon-cross-source": {
      "$description": "R9: 96 computes from sibling 48 (non-canonical, explicit $from).",
      "values": {
        "24": { "$file": "./packs/concept-pack/icon-24.svg" },
        "48": { "$file": "./packs/concept-pack/icon-48.svg" },
        "96": { "$from": "48", "$rules": ["scale-96"] }
      },
      "platforms": ["WEB", "PD"],
      "metadata": { "category": [], "tags": [], "legacyNames": [] }
    },

    "icon-themed": {
      "$description": "R10: future-proofing -- adds a non-numeric variant key (dark theme).",
      "values": {
        "24": { "$file": "./packs/concept-pack/icon-themed-light.svg" },
        "dark": { "$file": "./packs/concept-pack/icon-themed-dark.svg" },
        "16": null,
        "32": null
      },
      "platforms": ["WEB"],
      "metadata": { "category": [], "tags": [], "legacyNames": [] }
    },

    "icon-special-default": {
      "$description": "R12: asset-level canonical override -- this asset's canonical is 32, not the pack-level 24; ships only at 32.",
      "values": {
        "32": {
          "$file": "./packs/concept-pack/icon-special-32.svg",
          "default": true
        },
        "24": null,
        "16": null
      },
      "platforms": ["PD"],
      "metadata": { "category": [], "tags": [], "legacyNames": [] }
    },

    "icon-with-extensions": {
      "$description": "R16: $extensions carrying multiple reverse-DNS namespaces.",
      "values": {
        "24": { "$file": "./packs/concept-pack/icon-24.svg" }
      },
      "platforms": ["PD"],
      "metadata": { "category": [], "tags": [], "legacyNames": [] },
      "$extensions": {
        "com.figma.nodeId": "1:42",
        "com.figma.variableId": "VariableID:0:1",
        "com.acronis.review": "approved",
        "io.example.someTool": "anything"
      }
    }
  }
}
